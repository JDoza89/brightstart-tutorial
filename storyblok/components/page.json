{
  "name": "page",
  "display_name": "Page",
  "description": "Generic page wrapper. Body holds an ordered list of section blocks.",
  "is_root": true,
  "is_nestable": false,
  "schema": {
    "body": {
      "type": "bloks",
      "display_name": "Body",
      "restrict_components": true,
      "component_whitelist": [
        "hero_intro",
        "page_header",
        "banner_image",
        "services_grid",
        "feature_section",
        "cta_strip",
        "values_section",
        "team_section",
        "posts_grid",
        "faq_list",
        "contact_form",
        "contact_info"
      ],
      "minimum": 0,
      "maximum": 50
    },
    "tab_seo": {
      "type": "tab",
      "display_name": "SEO",
      "keys": ["seo_meta_title", "seo_meta_description", "seo_og_image"]
    },
    "seo_meta_title": { "type": "text", "display_name": "Meta title" },
    "seo_meta_description": { "type": "textarea", "display_name": "Meta description" },
    "seo_og_image": { "type": "asset", "filetypes": ["images"], "display_name": "OG image" }
  }
}
