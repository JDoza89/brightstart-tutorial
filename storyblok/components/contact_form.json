{
  "name": "contact_form",
  "display_name": "Contact Form",
  "description": "Configurable contact form with submit label and success message.",
  "is_root": false,
  "is_nestable": true,
  "schema": {
    "title": { "type": "text", "display_name": "Title" },
    "fields": {
      "type": "bloks",
      "display_name": "Fields",
      "restrict_components": true,
      "component_whitelist": ["form_field"],
      "minimum": 1,
      "maximum": 10
    },
    "submit_label": { "type": "text", "display_name": "Submit label", "default_value": "Send" },
    "success_message": { "type": "text", "display_name": "Success message" }
  }
}
