{
  "name": "faq_list",
  "display_name": "FAQ List",
  "description": "Optional heading + repeater of FAQ items.",
  "is_root": false,
  "is_nestable": true,
  "schema": {
    "title": { "type": "text", "display_name": "Title" },
    "items": {
